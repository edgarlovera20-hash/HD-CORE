# HD-CORE Environment Template
# Copy to .env and fill in real values. Never commit .env to version control.

NODE_ENV=development
APP_NAME=HD-CORE

# Dependency resolution mode for dependents (local | registry)
HD_CORE_MODE=local

# Identity service (future, Phase 3)
DATABASE_URL=postgresql://user:password@localhost:5432/hdcore
AUDIT_DB_URL=postgresql://user:password@localhost:5432/hdaudit
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRY=1h

# Logging
LOG_LEVEL=info
