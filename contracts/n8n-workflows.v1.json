{
  "$schema": "https://json-schema.org/draft/2020-12",
  "title": "N8N Workflow Catalog",
  "version": "1.0.0",
  "description": "Authoritative catalog of permitted n8n workflow automations for the Heavenly Dreams ecosystem.",
  "workflows": [
    {
      "workflowId": "WEB_LEAD_TO_CRM",
      "ownerPlatform": "HD-WEB",
      "trigger": "web_lead_form_submitted",
      "requiredServicePrincipal": "n8n-web-sp",
      "requiredPermissions": ["crm:lead:create"],
      "requiredMetadata": ["correlationId", "source", "timestamp"],
      "auditRequired": true,
      "humanReviewRequired": false,
      "forbiddenActions": ["crm:client:update", "crm:payment:create", "rbac:role:assign"]
    },
    {
      "workflowId": "CRM_OVERDUE_ALERT",
      "ownerPlatform": "HD-CRM",
      "trigger": "payment_overdue_detected",
      "requiredServicePrincipal": "n8n-crm-sp",
      "requiredPermissions": ["crm:client:read", "notification:send"],
      "requiredMetadata": ["correlationId", "clientId", "overdueDays", "timestamp"],
      "auditRequired": true,
      "humanReviewRequired": false,
      "forbiddenActions": ["crm:payment:create", "crm:payment:delete", "crm:client:delete"]
    },
    {
      "workflowId": "CRM_PAYMENT_COMMITMENT_REMINDER",
      "ownerPlatform": "HD-CRM",
      "trigger": "payment_commitment_due_soon",
      "requiredServicePrincipal": "n8n-crm-sp",
      "requiredPermissions": ["crm:client:read", "crm:commitment:read", "notification:send"],
      "requiredMetadata": ["correlationId", "clientId", "commitmentId", "dueDate", "timestamp"],
      "auditRequired": true,
      "humanReviewRequired": false,
      "forbiddenActions": ["crm:payment:create", "crm:payment:delete", "crm:commitment:delete"]
    },
    {
      "workflowId": "RH_CANDIDATE_FOLLOWUP_DRAFT",
      "ownerPlatform": "HD-RH",
      "trigger": "candidate_interview_completed",
      "requiredServicePrincipal": "n8n-rh-sp",
      "requiredPermissions": ["rh:candidate:read", "rh:interview:read"],
      "requiredMetadata": ["correlationId", "candidateId", "interviewId", "timestamp"],
      "auditRequired": true,
      "humanReviewRequired": true,
      "forbiddenActions": ["rh:candidate:hire", "rh:candidate:reject", "rh:offer:create"]
    },
    {
      "workflowId": "OPERATIONS_TASK_REMINDER",
      "ownerPlatform": "HD-OPERATIONS",
      "trigger": "task_due_approaching",
      "requiredServicePrincipal": "n8n-operations-sp",
      "requiredPermissions": ["operations:task:read", "notification:send"],
      "requiredMetadata": ["correlationId", "taskId", "assigneeId", "dueDate", "timestamp"],
      "auditRequired": true,
      "humanReviewRequired": false,
      "forbiddenActions": ["operations:task:delete", "rbac:role:assign", "crm:client:update"]
    },
    {
      "workflowId": "ADMIN_FINANCE_ANOMALY_ALERT",
      "ownerPlatform": "HD-ADMIN",
      "trigger": "finance_anomaly_detected",
      "requiredServicePrincipal": "n8n-admin-sp",
      "requiredPermissions": ["admin:finance:read", "notification:send"],
      "requiredMetadata": ["correlationId", "anomalyType", "affectedRecordId", "severity", "timestamp"],
      "auditRequired": true,
      "humanReviewRequired": true,
      "forbiddenActions": ["admin:payment:create", "admin:payment:delete", "admin:finance:delete", "rbac:role:assign"]
    },
    {
      "workflowId": "BRAIN_RISK_REVIEW_REQUEST",
      "ownerPlatform": "HD-BRAIN",
      "trigger": "risk_signal_threshold_exceeded",
      "requiredServicePrincipal": "n8n-brain-sp",
      "requiredPermissions": ["brain:kpi:read", "brain:risk:read", "notification:send"],
      "requiredMetadata": ["correlationId", "riskType", "affectedPlatform", "severity", "timestamp"],
      "auditRequired": true,
      "humanReviewRequired": true,
      "forbiddenActions": ["crm:client:update", "admin:finance:update", "rh:candidate:hire", "rbac:role:assign"]
    }
  ]
}
